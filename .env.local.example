# Database (separate PostgreSQL service)
DATABASE_URL="postgresql://ift_user:password@localhost:5432/ift_cms"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-strong-secret-here"

# Upload directory
# Dev:  UPLOAD_DIR=./uploads
# VPS:  UPLOAD_DIR=/var/www/ift/uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=10
